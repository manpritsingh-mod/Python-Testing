[MASTER]
init-hook='import sys; sys.path.append("src")'

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    too-few-public-methods,
    import-error

[FORMAT]
max-line-length=100
max-module-lines=1000

[DESIGN]
max-args=5
max-locals=15
max-returns=6
max-branches=12
max-statements=50

[REPORTS]
output-format=text
reports=yes
score=yes

[SIMILARITIES]
min-similarity-lines=4
ignore-comments=yes
ignore-docstrings=yes